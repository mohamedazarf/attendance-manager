# Configuration de connexion à l'appareil
DEVICE_IP=192.168.100.5
DEVICE_PORT=4370

# Configuration base de données
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=gestionDePointage

# Configuration sécurité
SECRET_KEY=generate_a_strong_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Configuration CORS (liste séparée par des virgules des origines autorisées)
CORS_ORIGINS=http://localhost:5173

# Règles métier
OVERTIME_THRESHOLD_HOURS=173.33

# Configuration alertes email
ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
